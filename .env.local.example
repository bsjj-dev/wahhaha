# LiveKit (optional - enables multi-user video via LiveKit Cloud or self-hosted)
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
NEXT_PUBLIC_LIVEKIT_URL=

# Signaling Server (optional - enables multi-user WebRTC peer connections)
# Run the included signaling server: node signaling-server.js
NEXT_PUBLIC_SIGNALING_URL=ws://localhost:8080
